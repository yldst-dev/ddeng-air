# ===== Telegram =====
# BotFather 에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 메시지를 받을 수 있는 채팅/그룹 ID 화이트리스트 (쉼표로 구분)
# 여기에 명시된 ID 로만 발송되며, 그 외에는 절대 전송되지 않습니다.
# 그룹 ID 는 보통 음수 (예: -1001234567890), 개인 채팅은 양수 입니다.
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890,123456789

# ===== 수집 조건 =====
# 왕복(RT) / 편도(OW)
TTANG_TRIP=RT
# 해외(L) / 국내(D)
TTANG_GUBUN=L
# "3일 이내 출발" = 오늘 ~ 오늘+N일
TTANG_DEPART_WITHIN_DAYS=2
# 성인 인원수
TTANG_ADT=1

# ===== 스케줄 =====
# node-cron 표현식 (기본: 매일 00, 09, 12, 17, 21시)
CRON_SCHEDULE=0 0,9,12,17,21 * * *
# true 면 시작 즉시(스케줄 시각과 무관) 1회 실행. 최초 가동 시 전체 발송에 유용.
RUN_ON_START=false
# 스케줄 및 날짜 계산 기준 타임존
TZ=Asia/Seoul

# ===== 저장소 =====
DATABASE_PATH=./data/listings.db

# ===== 발송 동작 =====
NOTIFY_ON_NEW=true
NOTIFY_ON_PRICE_DOWN=true
NOTIFY_ON_PRICE_UP=true
NOTIFY_ON_SOLD_OUT=true
# 텔레그램 rate limit 대비 메시지 간 지연(ms)
SEND_INTERVAL_MS=1200
# true 면 실제 발송 없이 콘솔에만 출력
DRY_RUN=false
